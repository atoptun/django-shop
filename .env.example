DEBUG=True
LOG_LEVEL=debug

# Django
DJANGO_SECRET_KEY=django-insecure-dev-key-change-in-production
DJANGO_ALLOWED_HOSTS=["localhost", "127.0.0.1", "localhost:8010", "127.0.0.1:8010", "django-shop.com"]

DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@django-shop.com
DJANGO_SUPERUSER_PASSWORD=rootroot


# Nginx proxy port, http://localhost:8010/
NGINX_OUT_PORT=8010

# Postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=django_shop
# POSTGRES_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# PgAdmin
PGADMIN_EMAIL=admin@local.org
PGADMIN_PASSWORD=rootroot
PGADMIN_PORT=8095
